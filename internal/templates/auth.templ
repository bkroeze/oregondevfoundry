templ ForbiddenPage(account AccountView) {
	<!DOCTYPE html>
	<html lang="en">
		@PageHead("Access denied")
		<body>
			<a class="skip-link" href="#main">Skip to content</a>
			@SiteHeader(account)
			<main id="main" class="account-main">
				<section class="account-panel">
					<p class="kicker">Authorization boundary</p>
					<h1>Access denied</h1>
					<p class="account-intro">Your account does not have access to this page.</p>
					<a class="button button-primary" href="/profile">Return to profile <span>↗</span></a>
				</section>
			</main>
			@PageFooter()
		</body>
	</html>
}
