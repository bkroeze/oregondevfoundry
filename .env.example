# HTTP listener port (defaults to 8080).
PORT=8080

# SQLite account/session data. Keep this path on persistent storage in production.
DATABASE_PATH=data/oregon-dev-foundry.db

# Local HTTP only. Production must use HTTPS and set this to true.
SESSION_COOKIE_SECURE=false

# Optional image name used by just docker-build and just docker-push.
IMAGE=ghcr.io/bkroeze/oregon-dev-foundry:latest

# Mailgun private API key. Never expose this in browser JavaScript or commit .env.
MAILGUN_API_KEY=key-replace-me

# Sending domain configured and verified in Mailgun, e.g. mg.oregondevfoundry.com
MAILGUN_DOMAIN=mg.oregondevfoundry.com

# Use "eu" only if the Mailgun domain is in the EU region; otherwise use "us".
MAILGUN_REGION=us

# Destination and verified sender identity.
CONTACT_TO=hello@oregondevfoundry.com
CONTACT_FROM=Oregon Dev Foundry <contact@mg.oregondevfoundry.com>

# Cloudflare Turnstile widget credentials for the deployed hostname.
TURNSTILE_SITE_KEY=replace-me
TURNSTILE_SECRET_KEY=replace-me
